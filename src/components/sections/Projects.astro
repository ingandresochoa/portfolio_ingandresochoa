---
import Section from "../Section.astro";

import { projects } from "@cv";

const featuredOrder = ["EziApply", "Construction Budgeting Platform"];
const featured = [...projects]
	.sort((a, b) => {
		const ai = featuredOrder.indexOf(a.name);
		const bi = featuredOrder.indexOf(b.name);
		const ar = ai === -1 ? 999 : ai;
		const br = bi === -1 ? 999 : bi;
		return ar - br;
	})
	.slice(0, 2);

const rest = projects.filter((p) => !featured.some((f) => f.name === p.name));
---

<Section
	id="projects"
	className={Astro.props.className}
	kicker="Portfolio"
	title="Featured projects"
	subtitle="A few projects that showcase backend engineering, automation, and product thinking."
>
	<div class="grid gap-4 md:grid-cols-2">
		{featured.map(({ name, description, highlights, url, github, isActive }) => (
			<article class="group relative overflow-hidden rounded-3xl bg-skin-button-muted/60 p-6 ring-1 ring-skin-muted/40 transition hover:-translate-y-0.5 hover:bg-skin-button-muted/80">
				<div class="flex items-start justify-between gap-3">
					<div>
						<div class="flex items-center gap-2">
							<h3 class="text-lg font-semibold text-skin-base">{name}</h3>
							{!isActive && (
								<span class="rounded-full bg-skin-muted/50 px-2 py-0.5 text-[11px] font-semibold text-skin-muted">
									In progress
								</span>
							)}
						</div>
						<p class="mt-2 text-sm text-skin-muted">{description}</p>
					</div>
					<div class="flex shrink-0 items-center gap-2">
						{url && isActive && (
							<a class="rounded-full bg-skin-button-accent px-3 py-1 text-xs font-semibold text-skin-inverted hover:bg-skin-button-accent-hover" href={url} target="_blank" rel="noreferrer">
								Demo
							</a>
						)}
						{github && (
							<a class="rounded-full bg-skin-button-muted px-3 py-1 text-xs font-semibold text-skin-base ring-1 ring-skin-muted/40 hover:bg-skin-button-muted/70" href={github} target="_blank" rel="noreferrer">
								Code
							</a>
						)}
					</div>
				</div>

				<ul class="mt-4 flex flex-wrap gap-2">
					{highlights?.slice(0, 6).map((h) => (
						<li class="rounded-full bg-skin-fill/70 px-3 py-1 text-[11px] font-medium text-skin-muted ring-1 ring-skin-muted/30">
							{h}
						</li>
					))}
				</ul>
			</article>
		))}
	</div>

	{rest.length > 0 && (
		<div class="mt-8">
			<h3 class="text-sm font-semibold text-skin-base">More</h3>
			<ul class="mt-3 grid gap-3">
				{rest.map(({ name, description, url, github }) => (
					<li class="flex flex-col gap-1 rounded-2xl bg-skin-button-muted/40 p-4 ring-1 ring-skin-muted/40 md:flex-row md:items-center md:justify-between">
						<div>
							<p class="text-sm font-semibold text-skin-base">{name}</p>
							<p class="text-sm text-skin-muted">{description}</p>
						</div>
						<div class="mt-2 flex items-center gap-2 md:mt-0">
							{url && (
								<a class="text-sm font-semibold text-skin-hue hover:underline" href={url} target="_blank" rel="noreferrer">
									Link
								</a>
							)}
							{github && (
								<a class="text-sm font-semibold text-skin-hue hover:underline" href={github} target="_blank" rel="noreferrer">
									GitHub
								</a>
							)}
						</div>
					</li>
				))}
			</ul>
		</div>
	)}
</Section>
