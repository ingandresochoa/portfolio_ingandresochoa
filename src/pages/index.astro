---
import Layout from "@/layouts/Layout.astro";

import About from "@/components/sections/About.astro";
import Education from "@/components/sections/Education.astro";
import Experience from "@/components/sections/Experience.astro";
import Hero from "@/components/sections/Hero.astro";
import Projects from "@/components/sections/Projects.astro";
import Skills from "@/components/sections/Skills.astro";
import Tail from "@/components/sections/Tail.astro";
import KeyboardManager from "@/components/KeyboardManager.astro";
import ThemeSwitch from "@/components/ThemeSwitch.astro";

import { basics } from "@cv";
const { name, label } = basics;
---

<Layout title={`${name} — ${label}`}>
	<main>
		<div class="mx-auto max-w-6xl px-6 pb-20 pt-10 md:px-10 md:pt-16 print:max-w-none print:px-0 print:pt-0">
			<div class="flex items-center justify-end print:hidden">
				<ThemeSwitch />
			</div>

			<Hero />

			<div class="mt-12 grid gap-10 md:mt-16 md:grid-cols-12">
				<section class="md:col-span-7 lg:col-span-8">
					<Projects className="print:hidden" />
					<Experience className="mt-10" />
				</section>
				<aside class="md:col-span-5 lg:col-span-4">
					<div class="mt-10 grid gap-10 md:mt-0">
						<About />
						<Skills className="print:hidden" />
						<Education />
					</div>
				</aside>
			</div>

			<Tail />
		</div>

		<KeyboardManager />
	</main>

</Layout>

<style>
	@page {
		size: auto;
		margin: 0mm;
	}
</style>
