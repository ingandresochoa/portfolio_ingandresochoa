---
import { basics } from "@cv";
import Section from "@/components/Section.astro";

const { name, image, location, profiles, email } = basics;
const { city, region } = location;
---

<Section className="pt-10 md:pt-14">
	<div class="grid gap-8 md:grid-cols-12 md:items-center">
		<div class="md:col-span-8">
			<p class="text-xs font-semibold uppercase tracking-[0.18em] text-skin-hue">Backend • Automation • Data</p>
			<h1 class="mt-3 text-4xl font-semibold tracking-tight text-skin-base md:text-6xl">
				{name}
			</h1>
			<p class="mt-4 max-w-2xl text-base text-skin-muted md:text-lg">
				{basics.summary}
			</p>

			<div class="mt-6 flex flex-wrap items-center gap-3">
				<a
					class="inline-flex items-center justify-center rounded-xl bg-skin-button-accent px-4 py-2 text-sm font-semibold text-skin-inverted shadow-sm transition-colors hover:bg-skin-button-accent-hover"
					href="#projects"
				>
					View projects
				</a>
				{email && (
					<a
						class="inline-flex items-center justify-center rounded-xl bg-skin-button-muted px-4 py-2 text-sm font-semibold text-skin-base ring-1 ring-skin-muted/40 transition-colors hover:bg-skin-button-muted/70"
						href={`mailto:${email}`}
					>
						Contact
					</a>
				)}
				<div class="flex items-center gap-3 text-sm text-skin-muted">
					<span class="inline-flex items-center gap-2">
						<span class="inline-block size-2 rounded-full bg-emerald-500"></span>
						Open to remote
					</span>
					<span class="hidden md:inline">•</span>
					<span class="hidden md:inline">{region}</span>
				</div>
			</div>

			<div class="mt-8 flex flex-wrap gap-2">
				{profiles?.map((p) => (
					<a
						class="rounded-full bg-skin-button-muted px-3 py-1 text-xs font-medium text-skin-base ring-1 ring-skin-muted/40 hover:bg-skin-button-muted/70"
						href={p.url}
						target="_blank"
						rel="noreferrer"
					>
						{p.network}
					</a>
				))}
			</div>
		</div>

		<div class="md:col-span-4">
			<div class="relative mx-auto w-fit">
				<div class="absolute -inset-4 -z-10 rounded-[28px] bg-gradient-to-b from-skin-hue/25 to-transparent blur-2xl"></div>
				<img
					class="aspect-square w-44 rounded-3xl object-cover ring-1 ring-skin-muted/30 md:w-56"
					src={image}
					alt={`${name} portrait`}
					loading="eager"
				/>
			</div>
		</div>
	</div>
</Section>
