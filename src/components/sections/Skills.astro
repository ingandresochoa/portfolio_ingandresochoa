---
import Section from "../Section.astro";
import { skills } from "@cv";
---

<Section id="skills" className={Astro.props.className} kicker="Toolkit" title="Skills">
	<ul class="flex flex-wrap gap-2">
		{skills.map(({ name }) => (
			<li class="rounded-full bg-skin-button-muted/60 px-3 py-1 text-xs font-medium text-skin-base ring-1 ring-skin-muted/40">
				{name}
			</li>
		))}
	</ul>
</Section>
