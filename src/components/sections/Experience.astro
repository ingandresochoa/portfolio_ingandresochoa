---
import Section from "../Section.astro";
import { work } from "@cv";

function formatDate(value: string | null) {
	if (!value) return "Present";
	const d = new Date(value);
	if (Number.isNaN(d.getTime())) return value;
	return d.toLocaleString("en-US", { month: "short", year: "numeric" });
}
---
<Section id="experience" className={Astro.props.className} kicker="Work" title="Experience">
	<div class="grid gap-4">
		{work.map(({ name, position, location, location_type, startDate, endDate, achievements, skills, url }) => (
			<article class="rounded-3xl bg-skin-button-muted/60 p-6 ring-1 ring-skin-muted/40">
				<div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
					<div>
						<h3 class="text-base font-semibold text-skin-base md:text-lg">
							{position}
							<span class="text-skin-muted">{" • "}</span>
							{url ? (
								<a class="text-skin-hue hover:underline" href={url} target="_blank" rel="noreferrer">
									{name}
								</a>
							) : (
								<span>{name}</span>
							)}
						</h3>
						<p class="text-sm text-skin-muted">
							{location}
							{location && location_type ? ` • ${location_type}` : ""}
						</p>
					</div>
					<p class="text-sm font-semibold text-skin-base">
						{formatDate(startDate)} — {formatDate(endDate)}
					</p>
				</div>

				{achievements?.length > 0 && (
					<details class="mt-4 group">
						<summary class="cursor-pointer select-none text-sm font-semibold text-skin-hue">
							Key impact
							<span class="ml-2 text-skin-muted group-open:hidden">+</span>
							<span class="ml-2 text-skin-muted hidden group-open:inline">–</span>
						</summary>
						<ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-skin-muted">
							{achievements.map((a) => (
								<li>{a}</li>
							))}
						</ul>
					</details>
				)}

				{skills?.length > 0 && (
					<ul class="mt-5 flex flex-wrap gap-2">
						{skills.slice(0, 12).map((s) => (
							<li class="rounded-full bg-skin-fill/70 px-3 py-1 text-[11px] font-medium text-skin-muted ring-1 ring-skin-muted/30">
								{s}
							</li>
						))}
					</ul>
				)}
			</article>
		))}
	</div>
</Section>