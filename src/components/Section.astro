---
const { className, title, id, kicker, subtitle } = Astro.props;
---

<section id={id} class:list={["scroll-mt-24", className]}>
	{(title || kicker || subtitle) && (
		<header class="mb-6">
			{kicker && <p class="text-xs font-semibold uppercase tracking-[0.14em] text-skin-hue">{kicker}</p>}
			{title && <h2 class="mt-2 text-2xl font-semibold tracking-tight text-skin-base md:text-3xl">{title}</h2>}
			{subtitle && <p class="mt-2 max-w-2xl text-sm text-skin-muted md:text-base">{subtitle}</p>}
		</header>
	)}
	<slot />
</section>
