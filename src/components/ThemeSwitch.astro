---
import Theme from "@/icons/themeSwitch.astro";
---

<div class="no-print inline-flex items-center">
	<button
		id="themeToggle"
		type="button"
		class="inline-flex items-center gap-2 rounded-xl bg-skin-button-muted px-3 py-2 text-sm font-semibold text-skin-base ring-1 ring-skin-muted/40 transition-colors hover:bg-skin-button-muted/70"
		aria-label="Toggle theme"
	>
		<span class="inline-flex size-5 items-center justify-center text-skin-hue">
			<Theme />
		</span>
		<span class="hidden sm:inline">Theme</span>
	</button>

	<script>
		const key = "theme";
		const root = document.documentElement;
		const mql = window.matchMedia("(prefers-color-scheme: dark)");

		function getStored() {
			const v = localStorage.getItem(key);
			return v === "light" || v === "dark" || v === "system" ? v : "system";
		}

		let mode = getStored();

		function apply() {
			const resolved = mode === "system" ? (mql.matches ? "dark" : "light") : mode;
			root.classList.remove("light", "dark");
			root.classList.add(resolved);
		}

		function cycleMode() {
			mode = mode === "system" ? "dark" : mode === "dark" ? "light" : "system";
			localStorage.setItem(key, mode);
			apply();
		}

		apply();

		mql.addEventListener?.("change", () => {
			if (mode === "system") apply();
		});

		const btn = document.getElementById("themeToggle");
		btn?.addEventListener("click", () => {
			cycleMode();
		});
	</script>
</div>
