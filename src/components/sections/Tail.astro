---
import { basics } from "@cv";

const linkedIn = basics.profiles?.find((p) => p.network === "LinkedIn")?.url;
const github = basics.profiles?.find((p) => p.network === "GitHub")?.url;
---

<footer class="mt-16 border-t border-skin-muted/30 pt-8 print:hidden">
	<div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
		<p class="text-xs text-skin-muted">
			© {new Date().getFullYear()} {basics.name}. Built with Astro.
		</p>
		<div class="flex flex-wrap gap-x-5 gap-y-2 text-sm">
			{basics.email && (
				<a class="font-semibold text-skin-hue hover:underline" href={`mailto:${basics.email}`}>
					Email
				</a>
			)}
			{linkedIn && (
				<a class="font-semibold text-skin-hue hover:underline" href={linkedIn} target="_blank" rel="noreferrer">
					LinkedIn
				</a>
			)}
			{github && (
				<a class="font-semibold text-skin-hue hover:underline" href={github} target="_blank" rel="noreferrer">
					GitHub
				</a>
			)}
		</div>
	</div>
</footer>
