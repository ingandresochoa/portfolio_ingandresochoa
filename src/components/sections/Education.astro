---
import Section from "../Section.astro";

import { education } from "@cv";
import { certificates } from "@cv";
---

<Section id="education" className={Astro.props.className} kicker="Background" title="Education & certificates">
	<ul class="mt-4 grid gap-3">
		{
			education.map(({ institution, startDate, endDate, area, url }) => {
				const startYear = new Date(startDate).getFullYear();
				const endYear = endDate != null ? new Date(endDate).getFullYear() : "Present";
				const years = `${startYear} — ${endYear}`;

				return (
					<li class="rounded-2xl bg-skin-button-muted/60 p-4 ring-1 ring-skin-muted/40">
						<p class="text-sm font-semibold text-skin-base">
							<a target="_blank" class="hover:text-skin-hue hover:underline" href={url} rel="noreferrer">
								{institution}
							</a>
						</p>
						<p class="text-sm text-skin-muted">{area}</p>
						<time class="mt-1 block text-xs font-semibold text-skin-base">{years}</time>
					</li>
				);
			})
		}
	</ul>

	{
		certificates.length > 0 && (
			<>
				<h3 class="mt-8 text-sm font-semibold text-skin-base">Certificates</h3>
				<ul class="mt-3 grid gap-3">
					{certificates.map(({ name, date, issuer, url }) => {
						const certificateYear = new Date(date).getFullYear();
						return (
							<li class="rounded-2xl bg-skin-button-muted/60 p-4 ring-1 ring-skin-muted/40">
								<p class="text-sm font-semibold text-skin-base">
									<a class="hover:text-skin-hue hover:underline" href={url} target="_blank" rel="noreferrer">
										{name}
									</a>
								</p>
								<p class="text-sm text-skin-muted">{issuer}</p>
								<time class="mt-1 block text-xs font-semibold text-skin-base">{certificateYear}</time>
							</li>
						);
					})}
				</ul>
			</>
		)
	}
</Section>
